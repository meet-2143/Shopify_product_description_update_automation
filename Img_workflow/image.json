      "parameters": {
        "jsCode": "// Get the raw text from the AI Agent\nlet rawOutput = items[0].json.output;\n\n// Clean up markdown\nrawOutput = rawOutput.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\ntry {\n  const parsed = JSON.parse(rawOutput);\n  const variant = parsed.variant;\n  let query = variant.search_query;\n// Remove any special characters that might confuse an image search\nquery = query.replace(/[^\\w\\s]/gi, ' ');\n\n  if (!variant) {\n    throw new Error(\"No variant found in AI response\");\n  }\n\n  // Return only ONE item to the HTTP Request node\n  return [{\n    json: {\n      title: variant.title,\n      search_query: variant.search_query\n    }\n  }];\n} catch (error) {\n  throw new Error(\"AI did not return valid JSON. Output: \" + rawOutput);\n}"
      },
