        "jsCode": "// Updated list: Pickles, Chutneys & Pastes\nconst alreadyUpdated = [\n  \"PREETHI-ZODIAC MIXER GRINDER\",\n  \"PREETHI-BLUE LEAF MIXES PLATINUM\",\n  \"WOODEN-FORK-100 GM\",\n  \"PATANJALI-DAMRU GLASS-400ML\",\n  \"PITAMBARI-50GM\",\n  \"IRON KADAI NO 2\",\n  \"IRON KADAI NO 10\",\n  \"SAUCE PAN\",\n  \"SANDSI PAKAD\",\n  \"LADDAL PAN 5\",\n  \"FUTURA-3TO7 LT RING\",\n  \"FUTURA-PRESSURE COOKER-5 LITRE\",\n  \"MASTER-CHEF SAUCEPAN-2 LITRE\",\n  \"FUTURA-KADAHI-26 CM\",\n  \"MILTON-THERMOWARE INSULATED CASSEROLE-1500ML\",\n  \"BELON NO 4 GUJRATI\",\n  \"SONEX- MILK PAN- NO.9\",\n  \"FUTURA -HANDI SAUCEPAN - 3 LT\",\n  \"FUTURA-TAVA GRIDDLE-26CM\",\n  \"FUTURA-DEEP FRY PAN-7.5LTR\",\n  \"FUTURA-TAVA-26CM\",\n  \"FUTURA-DOSA TAVA-33CM\",\n  \"FUTURA-FLAT TAVA INDUCTION-30CM\",\n  \"PITAMBARI-SHINING POWDER-150G\",\n  \"COSTCO\"\n];\n\nconst cleanList = alreadyUpdated.map(title =>\n  title.trim().toUpperCase()\n);\n\nreturn items.filter(item => {\n  const sheetTitle = (item.json.title || \"\")\n    .toString()\n    .trim()\n    .toUpperCase();\n\n  return !cleanList.includes(sheetTitle);\n});\n"
      },
